    // ---------------------------------------------
    // --------  Multi-Command Extension   ---------
    "multiCommand.commands": [
        {
            // This is a hack so <ctrl-s> can map to SAVE and "enter normal mode"
            "command": "multiCommand.vimSaveNormalMode",
            "sequence": [
                "extension.vim_escape",
                "workbench.action.files.save"
            ]
        },
    ]
}
